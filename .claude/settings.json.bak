{
  "permissions": {
    "additionalDirectories": [
      "/tmp",
      "~/go/pkg/mod"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/go-validate-reminder.sh\""
          }
        ]
      }
    ]
  }
}
